# ─── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PREFIX=api
API_VERSION=1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://fashionerp:fashionerp_secret@localhost:5432/fashionerp
DATABASE_MAX_CONNECTIONS=10
DATABASE_LOG_QUERIES=false

# ─── JWT ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars_long
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars_long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=fashionerp
JWT_AUDIENCE=fashionerp-client

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_DB=0
REDIS_TTL=3600
REDIS_KEY_PREFIX=fashionerp:

# ─── Storage ─────────────────────────────────────────────────
STORAGE_PROVIDER=local
UPLOAD_MAX_SIZE_MB=50

# AWS S3 (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=fashionerp-uploads

# Cloudflare R2 (optional)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=fashionerp-uploads
R2_ACCOUNT_ID=
R2_PUBLIC_URL=

# ─── Mail ─────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password
MAIL_FROM_NAME=FashionERP
MAIL_FROM_ADDRESS=noreply@fashionerp.com

# ─── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100
THROTTLE_AUTH_LIMIT=10

# ─── 2FA ─────────────────────────────────────────────────────
TWO_FA_APP_NAME=FashionERP

#  Keycloak SSO 
KEYCLOAK_AUTH_ENABLED=false
KEYCLOAK_URL=https://auth.hexalyte.com
KC_REALM=fashion-erp
KC_CLIENT_ID=fashion-erp-api
KC_CLIENT_SECRET=your_keycloak_client_secret
