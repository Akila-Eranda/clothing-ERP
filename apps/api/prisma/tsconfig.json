{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2021",
    "strictNullChecks": true,
    "noImplicitAny": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noEmit": true,
    "rootDir": "..",
    "paths": {
      "@prisma/client": ["../node_modules/.prisma/client"],
      "@prisma/client/*": ["../node_modules/.prisma/client/*"]
    }
  },
  "include": ["./**/*"],
  "exclude": ["../node_modules", "../dist"]
}
