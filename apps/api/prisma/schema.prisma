// ============================================================
// FashionERP Enterprise Prisma Schema
// ============================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RoleType {
  SUPER_ADMIN
  TENANT_ADMIN
  BRANCH_MANAGER
  CASHIER
  INVENTORY_MANAGER
  ACCOUNTANT
  HR_MANAGER
  VIEWER
  CUSTOM
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
  OUT_OF_STOCK
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE
  OPENING_STOCK
  STOCK_COUNT
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  ON_HOLD
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  WALLET
  CUSTOMER_CREDIT
  LOYALTY_POINTS
  MIXED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ReturnStatus {
  INITIATED
  APPROVED
  REJECTED
  COMPLETED
  REFUND_PROCESSED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  SIZE_ISSUE
  CUSTOMER_CHANGED_MIND
  DAMAGED
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum NotificationType {
  INFO
  LOW_STOCK
  NEW_SALE
  PAYMENT_DUE
  BIRTHDAY_REMINDER
  SYSTEM_ALERT
  CUSTOM_CAMPAIGN
  DAILY_SUMMARY
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum JournalEntryType {
  DEBIT
  CREDIT
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  ON_LEAVE
  LATE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum ShopType {
  CLOTHING
  GROCERY
  HARDWARE
  AGRICULTURE
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
  EXPIRED
}

enum WorkflowStatus {
  DRAFT
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum WorkflowTaskStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
  EXPIRED
}

enum StockCountStatus {
  DRAFT
  IN_PROGRESS
  POSTED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
  BUY_X_GET_Y
  FREE_SHIPPING
}

// ============================================================
// TENANT (SaaS Multi-Tenancy)
// ============================================================

model Tenant {
  id               String           @id @default(cuid())
  name             String
  subdomain        String           @unique
  logo             String?
  domain           String?          @unique
  email            String?
  phone            String?
  currency         String           @default("INR")
  country          String           @default("IN")
  timezone         String           @default("Asia/Kolkata")
  plan             SubscriptionPlan @default(STARTER)
  shopType         ShopType         @default(CLOTHING)
  status           TenantStatus     @default(TRIAL)
  trialEndsAt      DateTime?
  subscriptionId   String?
  billingEmail     String?
  maxBranches      Int              @default(1)
  maxUsers         Int              @default(5)
  maxProducts      Int              @default(500)
  settings         Json             @default("{}")
  metadata         Json             @default("{}")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  branches         Branch[]
  users            User[]
  products         Product[]
  categories       Category[]
  brands           Brand[]
  customers        Customer[]
  suppliers        Supplier[]
  sales            Sale[]
  purchases        PurchaseOrder[]
  employees        Employee[]
  accounts         Account[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  promotions       Promotion[]
  warehouses       Warehouse[]
  reports          Report[]
  fileUploads      FileUpload[]

  @@map("tenants")
}

// ============================================================
// BRANCH
// ============================================================

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  address     String?
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  gstNumber   String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  inventory   Inventory[]
  sales       Sale[]
  employees   Employee[]
  transfers   StockTransfer[]
  warehouses  Warehouse[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id                  String     @id @default(cuid())
  tenantId            String
  branchId            String?
  email               String
  phone               String?
  passwordHash        String
  firstName           String
  lastName            String
  avatar              String?
  gender              Gender?
  status              UserStatus @default(PENDING_VERIFICATION)
  emailVerified       Boolean    @default(false)
  phoneVerified       Boolean    @default(false)
  twoFactorEnabled    Boolean    @default(false)
  twoFactorSecret     String?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  loginAttempts       Int        @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?       @relation(fields: [branchId], references: [id])
  roles               UserRole[]
  sessions            Session[]
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  sales               Sale[]        @relation("CashierSales")
  notifications       UserNotification[]
  activityLogs        ActivityLog[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  type        RoleType @default(CUSTOM)
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  ipAddress   String?
  userAgent   String?
  deviceName  String?
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  family      String
  isUsed      Boolean  @default(false)
  isRevoked   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@map("password_resets")
}

// ============================================================
// PRODUCT & CATALOG
// ============================================================

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  parentId    String?
  name        String
  slug        String
  description String?
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model Brand {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  logo        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("brands")
}

model Product {
  id              String        @id @default(cuid())
  tenantId        String
  categoryId      String?
  brandId         String?
  name            String
  slug            String
  description     String?
  shortDesc       String?
  sku             String
  barcode         String?
  hsn             String?
  taxRate         Float         @default(18)
  costPrice       Float         @default(0)
  sellingPrice    Float         @default(0)
  mrp             Float         @default(0)
  status          ProductStatus @default(DRAFT)
  images          String[]      @default([])
  tags            String[]      @default([])
  attributes      Json          @default("{}")
  seoTitle        String?
  seoDescription  String?
  aiTags          String[]      @default([])
  isFeatured      Boolean       @default(false)
  hasVariants     Boolean       @default(true)
  trackInventory  Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?      @relation(fields: [categoryId], references: [id])
  brand           Brand?         @relation(fields: [brandId], references: [id])
  variants        ProductVariant[]
  collections     CollectionProduct[]
  promotions      PromotionProduct[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([status])
  @@map("products")
}

model ProductVariant {
  id            String        @id @default(cuid())
  productId     String
  sku           String
  barcode       String?
  name          String
  size          String?
  color         String?
  material      String?
  style         String?
  attributes    Json          @default("{}")
  costPrice     Float         @default(0)
  sellingPrice  Float         @default(0)
  mrp           Float         @default(0)
  images        String[]      @default([])
  isActive      Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory     Inventory[]
  saleItems     SaleItem[]
  returnItems   ReturnItem[]
  purchaseItems PurchaseOrderItem[]
  stockMovements InventoryLog[]
  transferItems  StockTransferItem[]
  reservations  InventoryReservation[]
  stockCountLines StockCountLine[]

  @@unique([productId, sku])
  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model Collection {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    CollectionProduct[]

  @@map("collections")
}

model CollectionProduct {
  collectionId String
  productId    String
  sortOrder    Int    @default(0)

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@map("collection_products")
}

// ============================================================
// WAREHOUSE & INVENTORY
// ============================================================

model Warehouse {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String
  name        String
  code        String
  address     String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch     @relation(fields: [branchId], references: [id])
  inventory   Inventory[]

  @@unique([tenantId, code])
  @@map("warehouses")
}

model Inventory {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  warehouseId   String?
  variantId     String
  quantity      Int      @default(0)
  reservedQty   Int      @default(0)
  damagedQty    Int      @default(0)
  returnedQty   Int      @default(0)
  avgCost       Float    @default(0)
  lastCost      Float    @default(0)
  minStockLevel Int      @default(0)
  maxStockLevel Int      @default(0)
  reorderPoint  Int      @default(5)
  lastCountedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  warehouse     Warehouse?     @relation(fields: [warehouseId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([branchId, variantId])
  @@index([tenantId])
  @@index([branchId])
  @@index([variantId])
  @@map("inventory")
}

model InventoryLog {
  id              String             @id @default(cuid())
  tenantId        String
  branchId        String
  variantId       String
  movementType    StockMovementType
  quantityChange  Int
  quantityBefore  Int
  quantityAfter   Int
  reservedBefore  Int                @default(0)
  reservedAfter   Int                @default(0)
  damagedBefore   Int                @default(0)
  damagedAfter    Int                @default(0)
  unitCost        Float?
  batchNumber     String?
  expiryDate      DateTime?
  correlationId   String?
  referenceId     String?
  referenceType   String?
  notes           String?
  performedBy     String?
  createdAt       DateTime           @default(now())

  variant         ProductVariant     @relation(fields: [variantId], references: [id])

  @@index([tenantId])
  @@index([branchId])
  @@index([variantId])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@index([correlationId])
  @@map("inventory_logs")
}

model InventoryReservation {
  id          String                     @id @default(cuid())
  tenantId    String
  branchId    String
  variantId   String
  quantity    Int
  status      InventoryReservationStatus @default(ACTIVE)
  sourceType  String
  sourceId    String
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime                   @default(now())
  releasedAt  DateTime?

  variant     ProductVariant             @relation(fields: [variantId], references: [id])

  @@index([tenantId, branchId, variantId, status])
  @@index([sourceType, sourceId])
  @@map("inventory_reservations")
}

model StockCountSession {
  id          String           @id @default(cuid())
  tenantId    String
  branchId    String
  warehouseId String?
  status      StockCountStatus @default(DRAFT)
  notes       String?
  countedBy   String?
  postedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  lines       StockCountLine[]

  @@index([tenantId, branchId, status])
  @@map("stock_count_sessions")
}

model StockCountLine {
  id          String            @id @default(cuid())
  sessionId   String
  variantId   String
  systemQty   Int
  countedQty  Int
  variance    Int

  session     StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variant     ProductVariant    @relation(fields: [variantId], references: [id])

  @@index([sessionId])
  @@map("stock_count_lines")
}

model StockTransfer {
  id              String         @id @default(cuid())
  tenantId        String
  fromBranchId    String
  toBranchId      String
  status          TransferStatus @default(PENDING)
  notes           String?
  requestedBy     String?
  approvedBy      String?
  dispatchedAt    DateTime?
  receivedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  fromBranch      Branch         @relation(fields: [fromBranchId], references: [id])
  items           StockTransferItem[]

  @@index([tenantId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id            String        @id @default(cuid())
  transferId    String
  variantId     String
  requestedQty  Int
  sentQty       Int           @default(0)
  receivedQty   Int           @default(0)

  transfer      StockTransfer    @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant       ProductVariant   @relation(fields: [variantId], references: [id])

  @@index([transferId])
  @@map("stock_transfer_items")
}

// ============================================================
// CUSTOMER & CRM
// ============================================================

model Customer {
  id              String       @id @default(cuid())
  tenantId        String
  code            String?
  firstName       String
  lastName        String?
  email           String?
  phone           String
  gender          Gender?
  dateOfBirth     DateTime?
  anniversary     DateTime?
  address         String?
  city            String?
  state           String?
  pincode         String?
  tier            CustomerTier @default(BRONZE)
  loyaltyPoints   Int          @default(0)
  walletBalance   Float        @default(0)
  creditLimit     Float        @default(0)
  creditBalance   Float        @default(0)
  totalSpent      Float        @default(0)
  totalOrders     Int          @default(0)
  isActive        Boolean      @default(true)
  referralCode    String?      @unique
  referredBy      String?
  notes           String?
  tags            String[]     @default([])
  metadata        Json         @default("{}")
  lastPurchaseAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales           Sale[]
  loyaltyTxns     LoyaltyTransaction[]
  walletTxns      WalletTransaction[]
  creditTxns      CustomerCreditTransaction[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([phone])
  @@map("customers")
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  customerId  String
  tenantId    String
  points      Int
  type        String
  description String?
  referenceId String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("loyalty_transactions")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  customerId  String
  tenantId    String
  amount      Float
  type        String
  description String?
  referenceId String?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("wallet_transactions")
}

model CustomerCreditTransaction {
  id          String   @id @default(cuid())
  customerId  String
  tenantId    String
  amount      Float
  type        String
  description String?
  referenceId String?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_credit_transactions")
}

// ============================================================
// SALES & POS
// ============================================================

model Sale {
  id                String        @id @default(cuid())
  tenantId          String
  branchId          String
  customerId        String?
  cashierId         String?
  invoiceNumber     String
  invoiceDate       DateTime      @default(now())
  status            SaleStatus    @default(COMPLETED)
  subtotal          Float
  discountAmount    Float         @default(0)
  taxAmount         Float         @default(0)
  roundOff          Float         @default(0)
  loyaltyDiscount   Float         @default(0)
  total             Float
  amountPaid        Float         @default(0)
  changeDue         Float         @default(0)
  paymentMethod     PaymentMethod @default(CASH)
  paymentStatus     PaymentStatus @default(COMPLETED)
  notes             String?
  couponCode        String?
  couponDiscount    Float         @default(0)
  pointsRedeemed    Int           @default(0)
  pointsEarned      Int           @default(0)
  isReturn          Boolean       @default(false)
  originalSaleId    String?
  terminalId        String?
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch        @relation(fields: [branchId], references: [id])
  customer          Customer?     @relation(fields: [customerId], references: [id])
  cashier           User?         @relation("CashierSales", fields: [cashierId], references: [id])
  items             SaleItem[]
  payments          SalePayment[]
  returns           Return[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([invoiceDate])
  @@map("sales")
}

model SaleItem {
  id            String   @id @default(cuid())
  saleId        String
  variantId     String
  productName   String
  variantName   String
  sku           String
  quantity      Int
  unitPrice     Float
  costPrice     Float    @default(0)
  discount      Float    @default(0)
  discountType  String   @default("FIXED")
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  total         Float
  createdAt     DateTime @default(now())

  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@map("sale_items")
}

model SalePayment {
  id            String        @id @default(cuid())
  saleId        String
  method        PaymentMethod
  amount        Float
  reference     String?
  status        PaymentStatus @default(COMPLETED)
  processedAt   DateTime      @default(now())

  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_payments")
}

model HeldBill {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String
  cashierId   String?
  customerId  String?
  label       String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, branchId])
  @@map("held_bills")
}

// ============================================================
// RETURNS & EXCHANGES
// ============================================================

model Return {
  id              String       @id @default(cuid())
  tenantId        String
  branchId        String
  originalSaleId  String
  returnNumber    String
  reason          ReturnReason
  status          ReturnStatus @default(INITIATED)
  returnType      String       @default("RETURN")
  notes           String?
  totalAmount     Float
  refundAmount    Float        @default(0)
  exchangeAmount  Float        @default(0)
  exchangeData    Json?
  restockItems    Boolean      @default(true)
  processedBy     String?
  approvedBy      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  originalSale    Sale         @relation(fields: [originalSaleId], references: [id])
  items           ReturnItem[]

  @@unique([tenantId, returnNumber])
  @@index([tenantId])
  @@map("returns")
}

model ReturnItem {
  id          String   @id @default(cuid())
  returnId    String
  variantId   String
  quantity    Int
  unitPrice   Float
  totalAmount Float

  return      Return         @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([returnId])
  @@map("return_items")
}

// ============================================================
// PROMOTIONS & COUPONS
// ============================================================

model Promotion {
  id              String       @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  discountType    DiscountType
  discountValue   Float
  minOrderAmount  Float        @default(0)
  maxDiscount     Float?
  usageLimit      Int?
  usageCount      Int          @default(0)
  perCustomerLimit Int?
  startsAt        DateTime
  endsAt          DateTime?
  isActive        Boolean      @default(true)
  applicableTo    String       @default("ALL")
  couponCode      String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products        PromotionProduct[]

  @@index([tenantId])
  @@index([couponCode])
  @@map("promotions")
}

model PromotionProduct {
  promotionId String
  productId   String

  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@map("promotion_products")
}

// ============================================================
// SUPPLIER & PURCHASING
// ============================================================

model Supplier {
  id            String   @id @default(cuid())
  tenantId      String
  code          String?
  name          String
  contactPerson String?
  email         String?
  phone         String
  address       String?
  city          String?
  state         String?
  pincode       String?
  gstNumber     String?
  panNumber     String?
  bankDetails   Json     @default("{}")
  creditDays    Int      @default(30)
  creditLimit   Float    @default(0)
  balance       Float    @default(0)
  rating        Float    @default(0)
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases     PurchaseOrder[]
  payments      SupplierPayment[]

  @@index([tenantId])
  @@map("suppliers")
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  tenantId        String
  branchId        String?
  supplierId      String
  poNumber        String
  status          PurchaseOrderStatus @default(DRAFT)
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  subtotal        Float               @default(0)
  taxAmount       Float               @default(0)
  discountAmount  Float               @default(0)
  total           Float               @default(0)
  paidAmount      Float               @default(0)
  notes           String?
  reference       String?
  paymentTerms    String?  @map("paymentterms")
  createdBy       String?
  approvedBy      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]
  payments        SupplierPayment[]

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id            String   @id @default(cuid())
  purchaseId    String
  variantId     String
  productName   String
  variantName   String
  sku           String
  orderedQty    Int
  receivedQty   Int      @default(0)
  rejectedQty   Int      @default(0)
  unitCost      Float
  discount      Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  total         Float

  purchase      PurchaseOrder  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@map("purchase_order_items")
}

model SupplierPayment {
  id          String   @id @default(cuid())
  tenantId    String
  supplierId  String
  purchaseId  String?
  amount      Float
  method      PaymentMethod
  reference   String?
  notes       String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  purchase    PurchaseOrder? @relation(fields: [purchaseId], references: [id])

  @@index([supplierId])
  @@map("supplier_payments")
}

// ============================================================
// ACCOUNTING
// ============================================================

model Account {
  id          String      @id @default(cuid())
  tenantId    String
  parentId    String?
  code        String
  name        String
  type        AccountType
  description String?
  isSystem    Boolean     @default(false)
  isActive    Boolean     @default(true)
  balance     Float       @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]     @relation("AccountHierarchy")
  debitLines  JournalLine[] @relation("DebitAccount")
  creditLines JournalLine[] @relation("CreditAccount")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("accounts")
}

model JournalEntry {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  entryNumber String
  description String
  referenceId String?
  referenceType String?
  date        DateTime @default(now())
  isPosted    Boolean  @default(false)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lines       JournalLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId])
  @@map("journal_entries")
}

model JournalLine {
  id              String           @id @default(cuid())
  journalEntryId  String
  debitAccountId  String?
  creditAccountId String?
  type            JournalEntryType
  amount          Float
  description     String?

  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  debitAccount    Account?      @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount   Account?      @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@map("journal_lines")
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  categoryId  String?
  amount      Float
  description String
  date        DateTime
  reference   String?
  paymentMethod PaymentMethod @default(CASH)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
  @@map("expenses")
}

// ============================================================
// HR & EMPLOYEES
// ============================================================

model Employee {
  id              String         @id @default(cuid())
  tenantId        String
  branchId        String?
  userId          String?
  code            String?
  firstName       String
  lastName        String
  email           String?
  phone           String
  gender          Gender?
  dateOfBirth     DateTime?
  address         String?
  department      String?
  designation     String?
  employmentType  EmploymentType @default(FULL_TIME)
  joiningDate     DateTime
  leavingDate     DateTime?
  basicSalary     Float          @default(0)
  bankDetails     Json           @default("{}")
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?      @relation(fields: [branchId], references: [id])
  attendances     Attendance[]
  payrolls        Payroll[]
  shifts          EmployeeShift[]
  leaveRequests   LeaveRequest[]

  @@index([tenantId])
  @@map("employees")
}

model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  tenantId    String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  createdAt   DateTime         @default(now())

  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@map("attendances")
}

model Payroll {
  id              String   @id @default(cuid())
  employeeId      String
  tenantId        String
  month           Int
  year            Int
  basicSalary     Float
  allowances      Float    @default(0)
  deductions      Float    @default(0)
  bonus           Float    @default(0)
  commission      Float    @default(0)
  netSalary       Float
  isPaid          Boolean  @default(false)
  paidAt          DateTime?
  paymentMethod   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@map("payrolls")
}

model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  tenantId    String
  startDate   DateTime
  endDate     DateTime
  leaveType   String   @default("CASUAL")
  reason      String?
  status      String   @default("PENDING")
  approvedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("leave_requests")
}

model Shift {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  startTime   String
  endTime     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  employees   EmployeeShift[]

  @@map("shifts")
}

model EmployeeShift {
  id          String   @id @default(cuid())
  employeeId  String
  shiftId     String
  date        DateTime
  isActive    Boolean  @default(true)

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift       Shift    @relation(fields: [shiftId], references: [id])

  @@index([employeeId])
  @@map("employee_shifts")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String              @id @default(cuid())
  tenantId    String
  type        NotificationType
  title       String
  message     String
  channel     NotificationChannel
  recipients  String[]
  data        Json                @default("{}")
  isRead      Boolean             @default(false)
  sentAt      DateTime?
  scheduledAt DateTime?
  createdAt   DateTime            @default(now())

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userNotifs  UserNotification[]

  @@index([tenantId])
  @@map("notifications")
}

model UserNotification {
  id             String   @id @default(cuid())
  userId         String
  notificationId String
  isRead         Boolean  @default(false)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@map("user_notifications")
}

// ============================================================
// FILE UPLOADS
// ============================================================

model FileUpload {
  id              String   @id @default(cuid())
  tenantId        String
  uploadedBy      String
  originalName    String
  filename        String
  mimeType        String
  size            Int
  url             String
  folder          String   @default("general")
  storageProvider String   @default("local")
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("file_uploads")
}

// ============================================================
// REPORTS
// ============================================================

model Report {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  type        String
  filters     Json     @default("{}")
  generatedBy String?
  fileUrl     String?
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("reports")
}

// ============================================================
// AUDIT & ACTIVITY LOGS
// ============================================================

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  oldData    Json?
  newData    Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model ActivityLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  description String?
  metadata   Json     @default("{}")
  ipAddress  String?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================================
// WORKFLOW ENGINE
// ============================================================

model WorkflowDefinition {
  id        String         @id @default(cuid())
  tenantId  String
  key       String
  name      String
  version   Int            @default(1)
  isActive  Boolean        @default(true)
  config    Json           @default("{}")
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  steps     WorkflowStep[]
  instances WorkflowInstance[]

  @@unique([tenantId, key, version])
  @@map("workflow_definitions")
}

model WorkflowStep {
  id             String             @id @default(cuid())
  definitionId   String
  stepOrder      Int
  name           String
  approverRole   String?
  approverUserId String?
  isRequired     Boolean            @default(true)

  definition     WorkflowDefinition @relation(fields: [definitionId], references: [id], onDelete: Cascade)

  @@index([definitionId])
  @@map("workflow_steps")
}

model WorkflowInstance {
  id           String             @id @default(cuid())
  tenantId     String
  definitionId String
  entityType   String
  entityId     String
  status       WorkflowStatus     @default(IN_PROGRESS)
  currentStep  Int                @default(1)
  initiatedBy  String?
  completedAt  DateTime?
  metadata     Json               @default("{}")
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  definition   WorkflowDefinition @relation(fields: [definitionId], references: [id])
  tasks        WorkflowTask[]
  events       WorkflowEvent[]

  @@unique([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@map("workflow_instances")
}

model WorkflowTask {
  id         String             @id @default(cuid())
  instanceId String
  stepOrder  Int
  assigneeId String?
  status     WorkflowTaskStatus @default(PENDING)
  comment    String?
  actedAt    DateTime?
  dueAt      DateTime?

  instance   WorkflowInstance   @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, status])
  @@index([assigneeId, status])
  @@map("workflow_tasks")
}

model WorkflowEvent {
  id         String           @id @default(cuid())
  instanceId String
  eventType  String
  fromStatus String?
  toStatus   String?
  actorId    String?
  payload    Json             @default("{}")
  createdAt  DateTime         @default(now())

  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId, createdAt])
  @@map("workflow_events")
}
