  tenantId        String
  uploadedBy      String
  originalName    String
  filename        String
  mimeType        String
  size            Int
  url             String
  folder          String   @default("general")
  storageProvider String   @default("local")
  createdAt       DateTime @default(now())

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("file_uploads")
}

// ============================================================
// REPORTS
// ============================================================

model Report {
