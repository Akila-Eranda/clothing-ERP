// ============================================================
// HexaOne Enterprise Prisma Schema
// ============================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../node_modules/.prisma/client"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum RoleType {
  SUPER_ADMIN
  TENANT_ADMIN
  BRANCH_MANAGER
  CASHIER
  INVENTORY_MANAGER
  ACCOUNTANT
  HR_MANAGER
  VIEWER
  CUSTOM
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
  ARCHIVED
  OUT_OF_STOCK
}

enum ProductKind {
  STANDARD
  VARIANT
  WEIGHTED
}

enum BarcodeMode {
  SHARED
  UNIQUE
}

enum StockMovementType {
  PURCHASE
  SALE
  RETURN
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  DAMAGE
  OPENING_STOCK
  STOCK_COUNT
}

enum SaleStatus {
  PENDING
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  ON_HOLD
}

enum PaymentMethod {
  CASH
  CARD
  UPI
  BANK_TRANSFER
  WALLET
  CUSTOMER_CREDIT
  LOYALTY_POINTS
  MIXED
  CHEQUE
  GIFT_VOUCHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum ReturnStatus {
  INITIATED
  APPROVED
  REJECTED
  COMPLETED
  REFUND_PROCESSED
}

enum ReturnReason {
  DEFECTIVE
  WRONG_ITEM
  WRONG_PART
  SIZE_ISSUE
  CUSTOMER_CHANGED_MIND
  DAMAGED
  WARRANTY
  EXPIRED
  QUALITY_ISSUE
  BATCH_ISSUE
  OTHER
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  CONFIRMED
  PARTIALLY_RECEIVED
  RECEIVED
  CLOSED
  CANCELLED
}

enum PurchaseRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CONVERTED
  CANCELLED
}

enum GoodsReceiptStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum GoodsReceiptSource {
  FROM_PO
  DIRECT
  QUICK
}

enum SupplierReturnStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum SupplierInvoiceStatus {
  DRAFT
  POSTED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

enum SupplierLedgerEntryType {
  GRN
  INVOICE
  PAYMENT
  RETURN
  ADJUSTMENT
  SYNC
  DEBIT_NOTE
}

enum SupplierDebitNoteStatus {
  DRAFT
  POSTED
  CANCELLED
}

enum CustomerTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  DIAMOND
}

enum NotificationType {
  INFO
  LOW_STOCK
  NEW_SALE
  PAYMENT_DUE
  BIRTHDAY_REMINDER
  SYSTEM_ALERT
  CUSTOM_CAMPAIGN
  DAILY_SUMMARY
  REORDER
  EXPIRY_ALERT
  SUPPLIER_DUE
  CHEQUE_DUE
  GRN_PENDING
  PO_PENDING
}

enum NotificationChannel {
  EMAIL
  SMS
  WHATSAPP
  PUSH
  IN_APP
}

enum JournalEntryType {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  VOID
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum FiscalYearStatus {
  OPEN
  CLOSED
}

enum AccountingPeriodStatus {
  OPEN
  CLOSED
  LOCKED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
  ON_LEAVE
  LATE
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum ShopType {
  CLOTHING
  GROCERY
  HARDWARE
  AGRICULTURE
  SPARE_PARTS
  TIRE_SHOP
  GENERAL
}

enum WarrantyClaimStatus {
  PENDING
  APPROVED
  REPLACED
  REJECTED
  CLOSED
}

enum QuotationStatus {
  DRAFT
  PENDING_APPROVAL
  SENT
  ACCEPTED
  REJECTED
  CONVERTED
  EXPIRED
}

enum TubeType {
  TUBE
  TUBELESS
}

enum JobCardStatus {
  OPEN
  IN_PROGRESS
  WAITING_PARTS
  COMPLETED
  INVOICED
  CANCELLED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_SERVICE
  COMPLETED
  NO_SHOW
  CANCELLED
}

enum ServiceLineType {
  PART
  LABOR
  SERVICE
}

enum TyreSerialStatus {
  IN_STOCK
  SOLD
  CLAIMED
}

enum ServiceReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum ServiceReminderChannel {
  SMS
  WHATSAPP
  EMAIL
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

enum TransferStatus {
  PENDING
  IN_TRANSIT
  RECEIVED
  CANCELLED
}

enum InventoryReservationStatus {
  ACTIVE
  RELEASED
  CONSUMED
  EXPIRED
}

enum WorkflowStatus {
  DRAFT
  IN_PROGRESS
  APPROVED
  REJECTED
  CANCELLED
  COMPLETED
}

enum WorkflowTaskStatus {
  PENDING
  APPROVED
  REJECTED
  SKIPPED
  EXPIRED
}

enum StockCountStatus {
  DRAFT
  IN_PROGRESS
  POSTED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
  BUY_X_GET_Y
  FREE_SHIPPING
}

// ============================================================
// TENANT (SaaS Multi-Tenancy)
// ============================================================

model Tenant {
  id               String           @id @default(cuid())
  name             String
  subdomain        String           @unique
  logo             String?
  domain           String?          @unique
  email            String?
  phone            String?
  currency         String           @default("INR")
  country          String           @default("IN")
  timezone         String           @default("Asia/Kolkata")
  plan             SubscriptionPlan @default(STARTER)
  shopType         ShopType         @default(CLOTHING)
  status           TenantStatus     @default(TRIAL)
  trialEndsAt      DateTime?
  subscriptionId   String?
  billingEmail     String?
  maxBranches      Int              @default(1)
  maxUsers         Int              @default(5)
  maxProducts      Int              @default(500)
  settings         Json             @default("{}")
  metadata         Json             @default("{}")
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  branches         Branch[]
  users            User[]
  products         Product[]
  categories       Category[]
  brands           Brand[]
  customers        Customer[]
  suppliers        Supplier[]
  sales            Sale[]
  purchases        PurchaseOrder[]
  purchaseRequests PurchaseRequest[]
  goodsReceipts    GoodsReceipt[]
  supplierReturns  SupplierReturn[]
  supplierInvoices SupplierInvoice[]
  supplierProductAssignments SupplierProductAssignment[]
  supplierLedgerEntries SupplierLedgerEntry[]
  supplierDebitNotes SupplierDebitNote[]
  taxRates           TaxRate[]
  vatReturns         VatReturn[]
  pettyCashFunds     PettyCashFund[]
  expenseClaims      ExpenseClaim[]
  reimbursements     Reimbursement[]
  fixedAssetCategories FixedAssetCategory[]
  fixedAssets        FixedAsset[]
  payrollSettings    PayrollSetting?
  payrollComponents  PayrollComponent[]
  payrollRuns        PayrollRun[]
  payslips           Payslip[]
  employees        Employee[]
  accounts         Account[]
  fiscalYears      FiscalYear[]
  accountingPeriods AccountingPeriod[]
  notifications    Notification[]
  bankAccounts     BankAccount[]
  cheques          Cheque[]
  cashBookEntries  CashBookEntry[]
  bankReconciliations BankReconciliation[]
  auditLogs        AuditLog[]
  promotions       Promotion[]
  warehouses       Warehouse[]
  reports          Report[]
  fileUploads      FileUpload[]
  vehicleBrands    VehicleBrand[]
  warrantyClaims   WarrantyClaim[]
  quotations       Quotation[]
  jobCards         JobCard[]
  appointments     Appointment[]
  workshopServices WorkshopServiceCatalog[]
  serviceReminders ServiceReminder[]
  tyreSerials      TyreSerial[]
  receiptPrintLogs ReceiptPrintLog[]
  cashRegisters    CashRegister[]
  cashMovements    CashMovement[]
  giftVouchers     GiftVoucher[]
  creditSchedules  CustomerCreditSchedule[]
  creditReminders  CustomerCreditReminder[]
  calendarNotes    CalendarNote[]
  calendarTasks    CalendarTask[]
  calendarMeetings CalendarMeeting[]
  documentNumberSeries DocumentNumberSeries[]
  accountingPreference AccountingPreference?
  accountMappings      AccountMapping[]
  accountingOutboxEvents AccountingOutboxEvent[]
  costCenters       CostCenter[]
  accountingBudgets AccountingBudget[]
  recurringJournals RecurringJournal[]
  exchangeRates     ExchangeRate[]

  @@map("tenants")
}

enum ReceiptPrintType {
  SALE
  PRE_BILL
  RETURN
  TEST
  PAYSLIP
  LABEL
  GRN
}

enum ReceiptPrintStatus {
  SUCCESS
  FAILED
  BROWSER_FALLBACK
  QUEUED
}

model ReceiptPrintLog {
  id             String              @id @default(cuid())
  tenantId       String
  branchId       String?
  userId         String?
  printType      ReceiptPrintType
  invoiceNumber  String?
  status         ReceiptPrintStatus
  printMode      String              @default("browser")
  printServerUrl String?
  printerName    String?
  errorMessage   String?
  metadata       Json                @default("{}")
  createdAt      DateTime            @default(now())

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?               @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
  @@index([invoiceNumber])
  @@map("receipt_print_logs")
}

// ============================================================
// BRANCH
// ============================================================

model Branch {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  code        String
  address     String?
  city        String?
  state       String?
  pincode     String?
  phone       String?
  email       String?
  gstNumber   String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  settings    Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  inventory   Inventory[]
  lots        InventoryLot[]
  sales       Sale[]
  employees   Employee[]
  transfers   StockTransfer[]
  warehouses  Warehouse[]
  cashRegisters CashRegister[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("branches")
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id                  String     @id @default(cuid())
  tenantId            String
  branchId            String?
  email               String
  phone               String?
  passwordHash        String
  firstName           String
  lastName            String
  avatar              String?
  gender              Gender?
  status              UserStatus @default(PENDING_VERIFICATION)
  emailVerified       Boolean    @default(false)
  phoneVerified       Boolean    @default(false)
  twoFactorEnabled    Boolean    @default(false)
  twoFactorSecret     String?
  lastLoginAt         DateTime?
  lastLoginIp         String?
  loginAttempts       Int        @default(0)
  lockedUntil         DateTime?
  passwordChangedAt   DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch              Branch?       @relation(fields: [branchId], references: [id])
  roles               UserRole[]
  sessions            Session[]
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  sales               Sale[]        @relation("CashierSales")
  notifications       UserNotification[]
  activityLogs        ActivityLog[]
  receiptPrintLogs    ReceiptPrintLog[]
  cashRegisters       CashRegister[] @relation("CashierRegisters")
  cashRegistersApproved CashRegister[] @relation("CashRegisterApprover")
  cashMovements       CashMovement[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  tenantId    String?
  name        String
  type        RoleType @default(CUSTOM)
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  ipAddress   String?
  userAgent   String?
  deviceName  String?
  isActive    Boolean  @default(true)
  expiresAt   DateTime
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

model RefreshToken {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  family      String
  isUsed      Boolean  @default(false)
  isRevoked   Boolean  @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([family])
  @@map("refresh_tokens")
}

model PasswordReset {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@map("password_resets")
}

// ============================================================
// PRODUCT & CATALOG
// ============================================================

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  parentId    String?
  name        String
  slug        String
  description String?
  image       String?
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  products    Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("categories")
}

model Brand {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  logo        String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("brands")
}

model Product {
  id              String        @id @default(cuid())
  tenantId        String
  categoryId      String?
  brandId         String?
  name            String
  slug            String
  description     String?
  shortDesc       String?
  sku             String
  barcode         String?
  hsn             String?
  taxRate         Float         @default(18)
  costPrice       Float         @default(0)
  sellingPrice    Float         @default(0)
  mrp             Float         @default(0)
  wholesalePrice  Float         @default(0)
  unit            String?
  productKind     ProductKind   @default(STANDARD)
  barcodeMode     BarcodeMode   @default(UNIQUE)
  allowNegativeStock Boolean    @default(false)
  allowDecimalSelling Boolean   @default(false)
  weightScaleReady Boolean      @default(false)
  status          ProductStatus @default(DRAFT)
  images          String[]      @default([])
  tags            String[]      @default([])
  attributes      Json          @default("{}")
  oemNumber       String?
  modelNumber     String?
  loadIndex       String?
  speedRating     String?
  tubeType        TubeType?
  pattern         String?
  warrantyMonths  Int?
  seoTitle        String?
  seoDescription  String?
  aiTags          String[]      @default([])
  isFeatured      Boolean       @default(false)
  hasVariants     Boolean       @default(true)
  trackInventory  Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category        Category?      @relation(fields: [categoryId], references: [id])
  brand           Brand?         @relation(fields: [brandId], references: [id])
  variants        ProductVariant[]
  collections     CollectionProduct[]
  promotions      PromotionProduct[]

  @@unique([tenantId, sku])
  @@index([tenantId])
  @@index([status])
  @@index([tenantId, productKind])
  @@map("products")
}

model ProductVariant {
  id            String        @id @default(cuid())
  productId     String
  sku           String
  barcode       String?
  name          String
  size          String?
  color         String?
  material      String?
  style         String?
  dotCode       String?
  attributes    Json          @default("{}")
  costPrice     Float         @default(0)
  sellingPrice  Float         @default(0)
  mrp           Float         @default(0)
  images        String[]      @default([])
  isActive      Boolean       @default(true)
  sortOrder     Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventory     Inventory[]
  lots          InventoryLot[]
  saleItems     SaleItem[]
  returnItems   ReturnItem[]
  purchaseItems PurchaseOrderItem[]
  purchaseRequestItems PurchaseRequestItem[]
  goodsReceiptItems GoodsReceiptItem[]
  supplierReturnItems SupplierReturnItem[]
  stockMovements InventoryLog[]
  transferItems  StockTransferItem[]
  reservations  InventoryReservation[]
  stockCountLines StockCountLine[]
  partCompatibilities PartCompatibility[]
  warrantyClaims WarrantyClaim[]
  quotationItems QuotationItem[]
  jobCardLines   JobCardLine[]
  tyreSerials    TyreSerial[]
  supplierAssignments SupplierProductAssignment[]

  @@unique([productId, sku])
  @@index([productId])
  @@index([sku])
  @@index([barcode])
  @@map("product_variants")
}

model Collection {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  slug        String
  description String?
  image       String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    CollectionProduct[]

  @@map("collections")
}

model CollectionProduct {
  collectionId String
  productId    String
  sortOrder    Int    @default(0)

  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@map("collection_products")
}

// ============================================================
// WAREHOUSE & INVENTORY
// ============================================================

model Warehouse {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String
  name        String
  code        String
  address     String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch      Branch     @relation(fields: [branchId], references: [id])
  inventory   Inventory[]
  lots        InventoryLot[]
  transfersFrom StockTransfer[] @relation("TransferFromWarehouse")
  transfersTo   StockTransfer[] @relation("TransferToWarehouse")

  @@unique([tenantId, code])
  @@index([tenantId, branchId])
  @@map("warehouses")
}

model Inventory {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String
  warehouseId   String
  variantId     String
  quantity      Int      @default(0)
  reservedQty   Int      @default(0)
  damagedQty    Int      @default(0)
  returnedQty   Int      @default(0)
  avgCost       Float    @default(0)
  lastCost      Float    @default(0)
  minStockLevel Int      @default(0)
  maxStockLevel Int      @default(0)
  reorderPoint  Int      @default(5)
  lastCountedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  branch        Branch         @relation(fields: [branchId], references: [id])
  warehouse     Warehouse      @relation(fields: [warehouseId], references: [id])
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([warehouseId, variantId])
  @@index([tenantId])
  @@index([branchId])
  @@index([branchId, variantId])
  @@index([variantId])
  @@map("inventory")
}

model InventoryLog {
  id              String             @id @default(cuid())
  tenantId        String
  branchId        String
  variantId       String
  movementType    StockMovementType
  quantityChange  Int
  quantityBefore  Int
  quantityAfter   Int
  reservedBefore  Int                @default(0)
  reservedAfter   Int                @default(0)
  damagedBefore   Int                @default(0)
  damagedAfter    Int                @default(0)
  unitCost        Float?
  batchNumber     String?
  expiryDate      DateTime?
  lotId           String?
  correlationId   String?
  referenceId     String?
  referenceType   String?
  notes           String?
  performedBy     String?
  createdAt       DateTime           @default(now())

  variant         ProductVariant     @relation(fields: [variantId], references: [id])
  lot             InventoryLot?      @relation(fields: [lotId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([branchId])
  @@index([variantId])
  @@index([createdAt])
  @@index([referenceType, referenceId])
  @@index([correlationId])
  @@index([lotId])
  @@index([tenantId, createdAt])
  @@map("inventory_logs")
}

model InventoryLot {
  id              String    @id @default(cuid())
  tenantId        String
  branchId        String
  warehouseId     String?
  variantId       String
  batchNumber     String?
  expiryDate      DateTime?
  manufactureDate DateTime?
  quantity        Int       @default(0)
  reservedQty     Int       @default(0)
  unitCost        Float     @default(0)
  receivedAt      DateTime  @default(now())
  referenceType   String?
  referenceId     String?
  notes           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  branch          Branch                   @relation(fields: [branchId], references: [id])
  warehouse       Warehouse?               @relation(fields: [warehouseId], references: [id])
  variant         ProductVariant           @relation(fields: [variantId], references: [id])
  reservations    InventoryLotReservation[]
  logs            InventoryLog[]

  @@index([tenantId, branchId, variantId])
  @@index([tenantId, warehouseId, variantId])
  @@index([tenantId, expiryDate])
  @@index([tenantId, branchId, expiryDate])
  @@index([batchNumber])
  @@index([variantId])
  @@map("inventory_lots")
}

model InventoryLotReservation {
  id          String                     @id @default(cuid())
  tenantId    String
  lotId       String
  quantity    Int
  status      InventoryReservationStatus @default(ACTIVE)
  sourceType  String
  sourceId    String
  createdAt   DateTime                   @default(now())
  releasedAt  DateTime?

  lot         InventoryLot               @relation(fields: [lotId], references: [id], onDelete: Cascade)

  @@index([lotId, status])
  @@index([tenantId, sourceType, sourceId])
  @@map("inventory_lot_reservations")
}

model InventoryReservation {
  id          String                     @id @default(cuid())
  tenantId    String
  branchId    String
  variantId   String
  quantity    Int
  status      InventoryReservationStatus @default(ACTIVE)
  sourceType  String
  sourceId    String
  expiresAt   DateTime?
  createdBy   String?
  createdAt   DateTime                   @default(now())
  releasedAt  DateTime?

  variant     ProductVariant             @relation(fields: [variantId], references: [id])

  @@index([tenantId, branchId, variantId, status])
  @@index([sourceType, sourceId])
  @@map("inventory_reservations")
}

model StockCountSession {
  id          String           @id @default(cuid())
  tenantId    String
  branchId    String
  warehouseId String?
  status      StockCountStatus @default(DRAFT)
  notes       String?
  countedBy   String?
  postedAt    DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  lines       StockCountLine[]

  @@index([tenantId, branchId, status])
  @@map("stock_count_sessions")
}

model StockCountLine {
  id          String            @id @default(cuid())
  sessionId   String
  variantId   String
  systemQty   Int
  countedQty  Int
  variance    Int

  session     StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  variant     ProductVariant    @relation(fields: [variantId], references: [id])

  @@index([sessionId])
  @@map("stock_count_lines")
}

model StockTransfer {
  id              String         @id @default(cuid())
  tenantId        String
  fromBranchId    String
  toBranchId      String
  fromWarehouseId String?
  toWarehouseId   String?
  status          TransferStatus @default(PENDING)
  notes           String?
  requestedBy     String?
  approvedBy      String?
  dispatchedAt    DateTime?
  receivedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  fromBranch      Branch         @relation(fields: [fromBranchId], references: [id])
  fromWarehouse   Warehouse?     @relation("TransferFromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse?     @relation("TransferToWarehouse", fields: [toWarehouseId], references: [id])
  items           StockTransferItem[]

  @@index([tenantId])
  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@map("stock_transfers")
}

model StockTransferItem {
  id            String        @id @default(cuid())
  transferId    String
  variantId     String
  requestedQty  Int
  sentQty       Int           @default(0)
  receivedQty   Int           @default(0)

  transfer      StockTransfer    @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant       ProductVariant   @relation(fields: [variantId], references: [id])
  lotAllocations StockTransferLot[]

  @@index([transferId])
  @@map("stock_transfer_items")
}

model StockTransferLot {
  id             String    @id @default(cuid())
  transferItemId String
  fromLotId      String?
  toLotId        String?
  batchNumber    String?
  expiryDate     DateTime?
  quantity       Int

  transferItem   StockTransferItem @relation(fields: [transferItemId], references: [id], onDelete: Cascade)

  @@index([transferItemId])
  @@map("stock_transfer_lots")
}

// ============================================================
// CUSTOMER & CRM
// ============================================================

model Customer {
  id              String       @id @default(cuid())
  tenantId        String
  code            String?
  firstName       String
  lastName        String?
  email           String?
  phone           String
  gender          Gender?
  dateOfBirth     DateTime?
  anniversary     DateTime?
  address         String?
  city            String?
  state           String?
  pincode         String?
  tier            CustomerTier @default(BRONZE)
  loyaltyPoints   Int          @default(0)
  walletBalance   Float        @default(0)
  creditLimit     Float        @default(0)
  creditBalance   Float        @default(0)
  creditDays      Int          @default(30)
  totalSpent      Float        @default(0)
  totalOrders     Int          @default(0)
  isActive        Boolean      @default(true)
  referralCode    String?      @unique
  referredBy      String?
  notes           String?
  tags            String[]     @default([])
  isFleet         Boolean      @default(false)
  metadata        Json         @default("{}")
  lastPurchaseAt  DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales           Sale[]
  loyaltyTxns     LoyaltyTransaction[]
  walletTxns      WalletTransaction[]
  creditTxns      CustomerCreditTransaction[]
  creditSchedules CustomerCreditSchedule[]
  creditReminders CustomerCreditReminder[]
  vehicles        CustomerVehicle[]
  warrantyClaims  WarrantyClaim[]
  quotations      Quotation[]
  jobCards        JobCard[]
  appointments    Appointment[]
  serviceReminders ServiceReminder[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([phone])
  @@index([tenantId, creditBalance])
  @@map("customers")
}

// ============================================================
// SPARE PARTS — VEHICLES, WARRANTY, QUOTATIONS
// ============================================================

model VehicleBrand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  models VehicleModel[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("vehicle_brands")
}

model VehicleModel {
  id             String   @id @default(cuid())
  tenantId       String
  brandId        String
  name           String
  yearFrom       Int?
  yearTo         Int?
  engineCapacity String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  brand            VehicleBrand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  compatibilities  PartCompatibility[]
  customerVehicles CustomerVehicle[]

  @@index([tenantId])
  @@index([brandId])
  @@map("vehicle_models")
}

model PartCompatibility {
  id             String   @id @default(cuid())
  tenantId       String
  vehicleModelId String
  variantId      String
  notes          String?
  createdAt      DateTime @default(now())

  vehicleModel VehicleModel   @relation(fields: [vehicleModelId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([vehicleModelId, variantId])
  @@index([tenantId])
  @@index([variantId])
  @@map("part_compatibilities")
}

model CustomerVehicle {
  id             String   @id @default(cuid())
  tenantId       String
  customerId     String
  vehicleModelId String?
  make           String?
  model          String?
  year           Int?
  engineCapacity String?
  registrationNo String?
  vin            String?
  chassisNo      String?
  notes          String?
  isPrimary      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicleModel VehicleModel? @relation(fields: [vehicleModelId], references: [id])
  appointments Appointment[]
  jobCards     JobCard[]

  @@index([customerId])
  @@index([tenantId])
  @@index([vin])
  @@index([chassisNo])
  @@map("customer_vehicles")
}

model WarrantyClaim {
  id                   String              @id @default(cuid())
  tenantId             String
  customerId           String
  variantId            String
  saleId               String?
  claimNumber          String
  status               WarrantyClaimStatus @default(PENDING)
  warrantyMonths       Int                 @default(0)
  purchaseDate         DateTime
  claimDate            DateTime            @default(now())
  issueDescription     String
  resolution           String?
  replacementVariantId String?
  resolvedAt           DateTime?
  resolvedBy           String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer       @relation(fields: [customerId], references: [id])
  variant  ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([tenantId, claimNumber])
  @@index([tenantId])
  @@index([customerId])
  @@map("warranty_claims")
}

model Quotation {
  id             String          @id @default(cuid())
  tenantId       String
  branchId       String?
  customerId     String?
  quoteNumber    String
  status         QuotationStatus @default(DRAFT)
  subtotal       Float           @default(0)
  taxAmount      Float           @default(0)
  discountAmount Float           @default(0)
  total          Float           @default(0)
  validUntil     DateTime?
  notes          String?
  createdBy      String?
  saleId         String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer?       @relation(fields: [customerId], references: [id])
  items    QuotationItem[]

  @@unique([tenantId, quoteNumber])
  @@index([tenantId])
  @@map("quotations")
}

model QuotationItem {
  id          String @id @default(cuid())
  quotationId String
  variantId   String
  quantity    Int
  unitPrice   Float
  discount    Float  @default(0)
  taxRate     Float  @default(0)
  total       Float  @default(0)

  quotation Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([quotationId])
  @@map("quotation_items")
}

// ============================================================
// TYRE SHOP — WORKSHOP, APPOINTMENTS, SERIAL TRACKING
// ============================================================

model WorkshopServiceCatalog {
  id              String   @id @default(cuid())
  tenantId        String
  code            String
  name            String
  description     String?
  category        String   @default("GENERAL")
  defaultPrice    Float    @default(0)
  durationMinutes Int      @default(30)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines   JobCardLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("workshop_service_catalog")
}

model JobCard {
  id                String         @id @default(cuid())
  tenantId          String
  branchId          String?
  customerId        String
  customerVehicleId String?
  appointmentId     String?        @unique
  jobNumber         String
  status            JobCardStatus  @default(OPEN)
  technicianId      String?
  odometer          Int?
  complaintNotes    String?
  beforeNotes       String?
  afterNotes        String?
  technicianNotes   String?
  customerSignature String?
  subtotal          Float          @default(0)
  taxAmount         Float          @default(0)
  discountAmount    Float          @default(0)
  total             Float          @default(0)
  saleId            String?
  quotationId       String?
  createdBy         String?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id])
  customerVehicle CustomerVehicle? @relation(fields: [customerVehicleId], references: [id])
  appointment     Appointment?     @relation(fields: [appointmentId], references: [id])
  lines           JobCardLine[]

  @@unique([tenantId, jobNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([status])
  @@map("job_cards")
}

model JobCardLine {
  id                 String          @id @default(cuid())
  jobCardId          String
  lineType           ServiceLineType @default(SERVICE)
  variantId          String?
  serviceCatalogId   String?
  description        String?
  quantity           Int             @default(1)
  unitPrice          Float           @default(0)
  discount           Float           @default(0)
  taxRate            Float           @default(0)
  total              Float           @default(0)

  jobCard         JobCard                 @relation(fields: [jobCardId], references: [id], onDelete: Cascade)
  variant         ProductVariant?         @relation(fields: [variantId], references: [id])
  serviceCatalog  WorkshopServiceCatalog? @relation(fields: [serviceCatalogId], references: [id])

  @@index([jobCardId])
  @@map("job_card_lines")
}

model Appointment {
  id                String            @id @default(cuid())
  tenantId          String
  branchId          String?
  customerId        String
  customerVehicleId String?
  appointmentNumber String
  status            AppointmentStatus @default(SCHEDULED)
  scheduledAt       DateTime
  durationMinutes   Int               @default(60)
  serviceTypes      String[]          @default([])
  notes             String?
  createdBy         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer        Customer         @relation(fields: [customerId], references: [id])
  customerVehicle CustomerVehicle? @relation(fields: [customerVehicleId], references: [id])
  jobCard         JobCard?

  @@unique([tenantId, appointmentNumber])
  @@index([tenantId])
  @@index([customerId])
  @@index([scheduledAt])
  @@map("appointments")
}

model TyreSerial {
  id           String           @id @default(cuid())
  tenantId     String
  variantId    String
  serialNumber String
  dotCode      String?
  branchId     String?
  status       TyreSerialStatus @default(IN_STOCK)
  jobCardId    String?
  saleId       String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([tenantId, serialNumber])
  @@index([tenantId])
  @@index([variantId])
  @@map("tyre_serials")
}

model ServiceReminder {
  id                String                 @id @default(cuid())
  tenantId          String
  customerId        String
  customerVehicleId String?
  appointmentId     String?
  jobCardId         String?
  reminderType      String                 @default("SERVICE_DUE")
  channel           ServiceReminderChannel @default(SMS)
  scheduledFor      DateTime
  message           String
  status            ServiceReminderStatus  @default(PENDING)
  sentAt            DateTime?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([tenantId])
  @@index([customerId])
  @@index([scheduledFor])
  @@index([status])
  @@map("service_reminders")
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  customerId  String
  tenantId    String
  points      Int
  type        String
  description String?
  referenceId String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("loyalty_transactions")
}

model WalletTransaction {
  id          String   @id @default(cuid())
  customerId  String
  tenantId    String
  amount      Float
  type        String
  description String?
  referenceId String?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("wallet_transactions")
}

model CustomerCreditTransaction {
  id          String   @id @default(cuid())
  customerId  String
  tenantId    String
  amount      Float
  paidAmount  Float    @default(0)
  type        String
  status      String   @default("OPEN")
  description String?
  referenceId String?
  dueDate     DateTime?
  createdAt   DateTime @default(now())

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  schedules   CustomerCreditSchedule[]

  @@index([customerId])
  @@index([tenantId])
  @@index([tenantId, dueDate])
  @@index([tenantId, status])
  @@map("customer_credit_transactions")
}

enum CreditScheduleStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CreditScheduleLineStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model CustomerCreditSchedule {
  id               String               @id @default(cuid())
  tenantId         String
  customerId       String
  chargeTxnId      String?
  totalAmount      Float
  installmentCount Int
  intervalDays     Int                  @default(30)
  startDate        DateTime
  status           CreditScheduleStatus @default(ACTIVE)
  notes            String?
  createdBy        String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer         Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)
  chargeTxn        CustomerCreditTransaction? @relation(fields: [chargeTxnId], references: [id])
  lines            CustomerCreditScheduleLine[]

  @@index([tenantId])
  @@index([customerId])
  @@map("customer_credit_schedules")
}

model CustomerCreditScheduleLine {
  id          String                   @id @default(cuid())
  scheduleId  String
  sequence    Int
  dueDate     DateTime
  amount      Float
  paidAmount  Float                    @default(0)
  status      CreditScheduleLineStatus @default(PENDING)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt

  schedule    CustomerCreditSchedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([dueDate])
  @@map("customer_credit_schedule_lines")
}

enum CreditReminderStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

model CustomerCreditReminder {
  id            String               @id @default(cuid())
  tenantId      String
  customerId    String
  chargeTxnId   String?
  scheduleLineId String?
  channel       NotificationChannel  @default(IN_APP)
  status        CreditReminderStatus @default(PENDING)
  dueDate       DateTime?
  title         String
  message       String
  sentAt        DateTime?
  createdBy     String?
  createdAt     DateTime             @default(now())

  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer      Customer             @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([customerId])
  @@index([tenantId, status])
  @@map("customer_credit_reminders")
}

// ============================================================
// SALES & POS
// ============================================================

model Sale {
  id                String        @id @default(cuid())
  tenantId          String
  branchId          String
  customerId        String?
  cashierId         String?
  invoiceNumber     String
  invoiceDate       DateTime      @default(now())
  status            SaleStatus    @default(COMPLETED)
  subtotal          Float
  discountAmount    Float         @default(0)
  taxAmount         Float         @default(0)
  roundOff          Float         @default(0)
  loyaltyDiscount   Float         @default(0)
  total             Float
  amountPaid        Float         @default(0)
  changeDue         Float         @default(0)
  paymentMethod     PaymentMethod @default(CASH)
  paymentStatus     PaymentStatus @default(COMPLETED)
  notes             String?
  couponCode        String?
  couponDiscount    Float         @default(0)
  pointsRedeemed    Int           @default(0)
  pointsEarned      Int           @default(0)
  helperEmployeeId  String?
  helperName        String?
  helperCommission  Float         @default(0)
  isReturn          Boolean       @default(false)
  originalSaleId    String?
  terminalId        String?
  metadata          Json          @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch        @relation(fields: [branchId], references: [id])
  customer          Customer?     @relation(fields: [customerId], references: [id])
  cashier           User?         @relation("CashierSales", fields: [cashierId], references: [id])
  helperEmployee    Employee?     @relation("HelperSales", fields: [helperEmployeeId], references: [id])
  items             SaleItem[]
  payments          SalePayment[]
  returns           Return[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([branchId])
  @@index([customerId])
  @@index([invoiceDate])
  @@index([helperEmployeeId])
  @@map("sales")
}

model SaleItem {
  id            String   @id @default(cuid())
  saleId        String
  /// Null for POS bill-only / custom lines (not linked to product catalog).
  variantId     String?
  productName   String
  variantName   String
  sku           String
  quantity      Int
  unitPrice     Float
  costPrice     Float    @default(0)
  discount      Float    @default(0)
  discountType  String   @default("FIXED")
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  total         Float
  createdAt     DateTime @default(now())

  sale          Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  variant       ProductVariant? @relation(fields: [variantId], references: [id])

  @@index([saleId])
  @@index([variantId])
  @@map("sale_items")
}

enum GiftVoucherStatus {
  ACTIVE
  PARTIALLY_USED
  REDEEMED
  EXPIRED
  CANCELLED
}

model GiftVoucher {
  id                String            @id @default(cuid())
  tenantId          String
  branchId          String?
  code              String
  initialAmount     Float
  balance           Float
  status            GiftVoucherStatus @default(ACTIVE)
  issuedToName      String?
  issuedToCustomerId String?
  issuedBySaleId    String?
  expiresAt         DateTime?
  notes             String?
  createdBy         String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("gift_vouchers")
}

model SalePayment {
  id            String        @id @default(cuid())
  saleId        String
  method        PaymentMethod
  amount        Float
  reference     String?
  status        PaymentStatus @default(COMPLETED)
  processedAt   DateTime      @default(now())

  sale          Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@map("sale_payments")
}

model HeldBill {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String
  cashierId   String?
  customerId  String?
  label       String?
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, branchId])
  @@map("held_bills")
}

// ============================================================
// RETURNS & EXCHANGES
// ============================================================

model Return {
  id              String       @id @default(cuid())
  tenantId        String
  branchId        String
  originalSaleId  String
  returnNumber    String
  reason          ReturnReason
  status          ReturnStatus @default(INITIATED)
  returnType      String       @default("RETURN")
  notes           String?
  totalAmount     Float
  refundAmount    Float        @default(0)
  exchangeAmount  Float        @default(0)
  exchangeData    Json?
  restockItems    Boolean      @default(true)
  processedBy     String?
  approvedBy      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  originalSale    Sale         @relation(fields: [originalSaleId], references: [id])
  items           ReturnItem[]

  @@unique([tenantId, returnNumber])
  @@index([tenantId])
  @@map("returns")
}

model ReturnItem {
  id          String   @id @default(cuid())
  returnId    String
  variantId   String
  quantity    Int
  unitPrice   Float
  totalAmount Float

  return      Return         @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([returnId])
  @@map("return_items")
}

// ============================================================
// PROMOTIONS & COUPONS
// ============================================================

model Promotion {
  id              String       @id @default(cuid())
  tenantId        String
  name            String
  description     String?
  discountType    DiscountType
  discountValue   Float
  minOrderAmount  Float        @default(0)
  maxDiscount     Float?
  usageLimit      Int?
  usageCount      Int          @default(0)
  perCustomerLimit Int?
  startsAt        DateTime
  endsAt          DateTime?
  isActive        Boolean      @default(true)
  applicableTo    String       @default("ALL")
  couponCode      String?      @unique
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products        PromotionProduct[]

  @@index([tenantId])
  @@index([couponCode])
  @@map("promotions")
}

model PromotionProduct {
  promotionId String
  productId   String

  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
  @@map("promotion_products")
}

// ============================================================
// SUPPLIER & PURCHASING
// ============================================================

model Supplier {
  id            String   @id @default(cuid())
  tenantId      String
  code          String?
  name          String
  contactPerson String?
  email         String?
  phone         String
  address       String?
  city          String?
  state         String?
  pincode       String?
  gstNumber     String?
  panNumber     String?
  bankDetails   Json     @default("{}")
  creditDays    Int      @default(30)
  creditLimit   Float    @default(0)
  balance       Float    @default(0)
  rating        Float    @default(0)
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchases     PurchaseOrder[]
  payments      SupplierPayment[]
  goodsReceipts GoodsReceipt[]
  returns       SupplierReturn[]
  invoices      SupplierInvoice[]
  productAssignments SupplierProductAssignment[]
  ledgerEntries SupplierLedgerEntry[]
  debitNotes    SupplierDebitNote[]

  @@index([tenantId])
  @@map("suppliers")
}

model SupplierProductAssignment {
  id                String   @id @default(cuid())
  tenantId          String
  supplierId        String
  variantId         String
  supplierProductCode String?
  leadTimeDays      Int?
  lastBuyingPrice   Float?
  minOrderQty       Float?
  isPreferred       Boolean  @default(false)
  isActive          Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier          Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  variant           ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([supplierId, variantId])
  @@index([tenantId, supplierId])
  @@index([tenantId, variantId])
  @@map("supplier_product_assignments")
}

model SupplierLedgerEntry {
  id            String                  @id @default(cuid())
  tenantId      String
  supplierId    String
  entryType     SupplierLedgerEntryType
  amount        Float
  balanceAfter  Float
  referenceType String?
  referenceId   String?
  notes         String?
  createdBy     String?
  createdAt     DateTime                @default(now())

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier      Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([tenantId, supplierId, createdAt])
  @@index([referenceType, referenceId])
  @@map("supplier_ledger_entries")
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  tenantId        String
  branchId        String?
  supplierId      String
  poNumber        String
  status          PurchaseOrderStatus @default(DRAFT)
  orderDate       DateTime            @default(now())
  expectedDate    DateTime?
  receivedDate    DateTime?
  subtotal        Float               @default(0)
  taxAmount       Float               @default(0)
  discountAmount  Float               @default(0)
  total           Float               @default(0)
  paidAmount      Float               @default(0)
  notes           String?
  reference       String?
  paymentTerms    String?  @map("paymentterms")
  createdBy       String?
  approvedBy      String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  items           PurchaseOrderItem[]
  payments        SupplierPayment[]
  paymentAllocations SupplierPaymentAllocation[]
  goodsReceipts   GoodsReceipt[]
  supplierReturns SupplierReturn[]
  invoices        SupplierInvoice[]
  purchaseRequest PurchaseRequest?

  @@unique([tenantId, poNumber])
  @@index([tenantId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id            String   @id @default(cuid())
  purchaseId    String
  variantId     String
  productName   String
  variantName   String
  sku           String
  orderedQty    Int
  receivedQty   Int      @default(0)
  rejectedQty   Int      @default(0)
  unitCost      Float
  discount      Float    @default(0)
  taxRate       Float    @default(0)
  taxAmount     Float    @default(0)
  total         Float

  purchase      PurchaseOrder  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id])

  @@index([purchaseId])
  @@map("purchase_order_items")
}

model SupplierPayment {
  id          String   @id @default(cuid())
  tenantId    String
  supplierId  String
  purchaseId  String?
  invoiceId   String?
  amount      Float
  method      PaymentMethod
  reference   String?
  notes       String?
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  supplier    Supplier                    @relation(fields: [supplierId], references: [id])
  purchase    PurchaseOrder?              @relation(fields: [purchaseId], references: [id])
  invoice     SupplierInvoice?            @relation(fields: [invoiceId], references: [id])
  allocations SupplierPaymentAllocation[]

  @@index([supplierId])
  @@index([invoiceId])
  @@index([tenantId, paidAt])
  @@map("supplier_payments")
}

// Per-PO (or invoice) application of a supplier payment — supports multi-PO FIFO.
model SupplierPaymentAllocation {
  id          String   @id @default(cuid())
  tenantId    String
  paymentId   String
  purchaseId  String?
  invoiceId   String?
  amount      Float
  createdAt   DateTime @default(now())

  payment     SupplierPayment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  purchase    PurchaseOrder?   @relation(fields: [purchaseId], references: [id])
  invoice     SupplierInvoice? @relation(fields: [invoiceId], references: [id])

  @@index([paymentId])
  @@index([purchaseId])
  @@index([invoiceId])
  @@map("supplier_payment_allocations")
}

model PurchaseRequest {
  id              String                @id @default(cuid())
  tenantId        String
  branchId        String?
  requestNumber   String
  status          PurchaseRequestStatus @default(DRAFT)
  notes           String?
  createdBy       String?
  approvedBy      String?
  convertedPoId   String?               @unique
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  convertedPo     PurchaseOrder?        @relation(fields: [convertedPoId], references: [id])
  items           PurchaseRequestItem[]

  @@unique([tenantId, requestNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id            String   @id @default(cuid())
  requestId     String
  variantId     String
  productName   String
  variantName   String
  sku           String
  requestedQty  Int
  unitCostHint  Float    @default(0)
  notes         String?

  request       PurchaseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  variant       ProductVariant  @relation(fields: [variantId], references: [id])

  @@index([requestId])
  @@map("purchase_request_items")
}

model GoodsReceipt {
  id                  String             @id @default(cuid())
  tenantId            String
  branchId            String
  grnNumber           String
  source              GoodsReceiptSource @default(FROM_PO)
  status              GoodsReceiptStatus @default(POSTED)
  purchaseId          String?
  supplierId          String
  receivedAt          DateTime           @default(now())
  receivedBy          String?
  notes               String?
  supplierInvoiceRef  String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  tenant              Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchase            PurchaseOrder?     @relation(fields: [purchaseId], references: [id])
  supplier            Supplier           @relation(fields: [supplierId], references: [id])
  items               GoodsReceiptItem[]
  returns             SupplierReturn[]
  invoices            SupplierInvoice[]

  @@unique([tenantId, grnNumber])
  @@index([tenantId])
  @@index([purchaseId])
  @@index([supplierId])
  @@map("goods_receipts")
}

model GoodsReceiptItem {
  id              String    @id @default(cuid())
  grnId           String
  purchaseItemId  String?
  variantId       String
  productName     String
  variantName     String
  sku             String
  orderedQty      Int       @default(0)
  receivedQty     Int
  rejectedQty     Int       @default(0)
  unitCost        Float     @default(0)
  batchNumber     String?
  expiryDate      DateTime?
  manufactureDate DateTime?
  lotId           String?

  grn             GoodsReceipt   @relation(fields: [grnId], references: [id], onDelete: Cascade)
  variant         ProductVariant @relation(fields: [variantId], references: [id])

  @@index([grnId])
  @@index([variantId])
  @@map("goods_receipt_items")
}

model SupplierReturn {
  id              String               @id @default(cuid())
  tenantId        String
  branchId        String
  returnNumber    String
  supplierId      String
  purchaseId      String?
  goodsReceiptId  String?
  status          SupplierReturnStatus @default(DRAFT)
  reason          String?
  notes           String?
  createdBy       String?
  postedAt        DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier             @relation(fields: [supplierId], references: [id])
  purchase        PurchaseOrder?       @relation(fields: [purchaseId], references: [id])
  goodsReceipt    GoodsReceipt?        @relation(fields: [goodsReceiptId], references: [id])
  items           SupplierReturnItem[]

  @@unique([tenantId, returnNumber])
  @@index([tenantId])
  @@index([supplierId])
  @@map("supplier_returns")
}

model SupplierReturnItem {
  id          String   @id @default(cuid())
  returnId    String
  variantId   String
  productName String
  sku         String
  quantity    Int
  unitCost    Float    @default(0)
  lotId       String?
  batchNumber String?
  reason      String?

  returnDoc   SupplierReturn @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([returnId])
  @@map("supplier_return_items")
}

model SupplierInvoice {
  id              String                @id @default(cuid())
  tenantId        String
  supplierId      String
  invoiceNumber   String
  invoiceDate     DateTime              @default(now())
  dueDate         DateTime?
  purchaseId      String?
  goodsReceiptId  String?
  subtotal        Float                 @default(0)
  taxAmount       Float                 @default(0)
  total           Float                 @default(0)
  paidAmount      Float                 @default(0)
  status          SupplierInvoiceStatus @default(DRAFT)
  notes           String?
  createdBy       String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  tenant          Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier        Supplier              @relation(fields: [supplierId], references: [id])
  purchase        PurchaseOrder?        @relation(fields: [purchaseId], references: [id])
  goodsReceipt    GoodsReceipt?         @relation(fields: [goodsReceiptId], references: [id])
  payments        SupplierPayment[]
  paymentAllocations SupplierPaymentAllocation[]
  debitNotes      SupplierDebitNote[]

  @@unique([tenantId, supplierId, invoiceNumber])
  @@index([tenantId])
  @@index([supplierId])
  @@index([dueDate])
  @@map("supplier_invoices")
}

model SupplierDebitNote {
  id            String                  @id @default(cuid())
  tenantId      String
  supplierId    String
  noteNumber    String
  noteDate      DateTime                @default(now())
  amount        Float
  appliedAmount Float                   @default(0)
  status        SupplierDebitNoteStatus @default(POSTED)
  reason        String?
  referenceType String?
  referenceId   String?
  invoiceId     String?
  purchaseId    String?
  createdBy     String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier      Supplier                @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  invoice       SupplierInvoice?        @relation(fields: [invoiceId], references: [id])

  @@unique([tenantId, noteNumber])
  @@index([tenantId, supplierId])
  @@index([supplierId])
  @@map("supplier_debit_notes")
}

// ============================================================
// VAT & TAX (Sprint 7)
// ============================================================

enum TaxDirection {
  OUTPUT
  INPUT
  BOTH
}

enum VatReturnStatus {
  DRAFT
  SUBMITTED
  FILED
  CANCELLED
}

model TaxRate {
  id                String       @id @default(cuid())
  tenantId          String
  code              String
  name              String
  rate              Float
  direction         TaxDirection @default(BOTH)
  isDefault         Boolean      @default(false)
  isActive          Boolean      @default(true)
  isInclusive       Boolean      @default(false)
  description       String?
  outputGlAccountId String?
  inputGlAccountId  String?
  effectiveFrom     DateTime?
  effectiveTo       DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  tenant            Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("tax_rates")
}

model VatReturn {
  id             String          @id @default(cuid())
  tenantId       String
  periodStart    DateTime
  periodEnd      DateTime
  status         VatReturnStatus @default(DRAFT)
  outputVat      Float           @default(0)
  inputVat       Float           @default(0)
  netVat         Float           @default(0)
  salesNet       Float           @default(0)
  purchasesNet   Float           @default(0)
  salesGross     Float           @default(0)
  purchasesGross Float           @default(0)
  journalEntryId String?
  notes          String?
  filedAt        DateTime?
  filedBy        String?
  createdBy      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, periodStart, periodEnd])
  @@index([tenantId, status])
  @@map("vat_returns")
}

// ============================================================
// PETTY CASH (Sprint 8)
// ============================================================

enum PettyCashTxnType {
  OPENING
  DISBURSEMENT
  REPLENISHMENT
  ADJUSTMENT
}

enum ExpenseClaimStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REIMBURSED
  CANCELLED
}

enum ReimbursementStatus {
  PAID
  VOID
}

model PettyCashFund {
  id              String   @id @default(cuid())
  tenantId        String
  branchId        String?
  code            String
  name            String
  floatAmount     Float    @default(0)
  currentBalance  Float    @default(0)
  glAccountId     String?
  bankAccountId   String?
  isActive        Boolean  @default(true)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions    PettyCashTransaction[]
  claims          ExpenseClaim[]
  reimbursements  Reimbursement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@map("petty_cash_funds")
}

model PettyCashTransaction {
  id                 String           @id @default(cuid())
  tenantId           String
  fundId             String
  type               PettyCashTxnType
  txnDate            DateTime         @default(now())
  amount             Float
  description        String
  category           String?
  expenseGlAccountId String?
  receiptRef         String?
  claimId            String?
  reimbursementId    String?
  journalEntryId     String?
  balanceAfter       Float            @default(0)
  createdBy          String?
  createdAt          DateTime         @default(now())

  fund               PettyCashFund    @relation(fields: [fundId], references: [id], onDelete: Cascade)

  @@index([tenantId, fundId])
  @@index([tenantId, txnDate])
  @@index([fundId, txnDate])
  @@map("petty_cash_transactions")
}

model ExpenseClaim {
  id                 String             @id @default(cuid())
  tenantId           String
  fundId             String?
  branchId           String?
  claimantName       String
  employeeId         String?
  claimDate          DateTime           @default(now())
  description        String
  amount             Float
  category           String?
  expenseGlAccountId String?
  receiptRef         String?
  status             ExpenseClaimStatus @default(DRAFT)
  notes              String?
  rejectionReason    String?
  approvedBy         String?
  approvedAt         DateTime?
  createdBy          String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fund               PettyCashFund?     @relation(fields: [fundId], references: [id])
  reimbursement      Reimbursement?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, claimDate])
  @@map("expense_claims")
}

model Reimbursement {
  id                  String               @id @default(cuid())
  tenantId            String
  claimId             String               @unique
  fundId              String?
  amount              Float
  payDate             DateTime             @default(now())
  payFromBankAccountId String?
  reference           String?
  notes               String?
  status              ReimbursementStatus  @default(PAID)
  journalEntryId      String?
  createdBy           String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  claim               ExpenseClaim         @relation(fields: [claimId], references: [id], onDelete: Cascade)
  fund                PettyCashFund?       @relation(fields: [fundId], references: [id])

  @@index([tenantId])
  @@index([tenantId, payDate])
  @@map("reimbursements")
}

// ============================================================
// FIXED ASSETS (Sprint 9)
// ============================================================

enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  NONE
}

enum FixedAssetStatus {
  ACTIVE
  FULLY_DEPRECIATED
  DISPOSED
}

enum FixedAssetTxnType {
  ACQUISITION
  DEPRECIATION
  DISPOSAL
  TRANSFER
  ADJUSTMENT
}

model FixedAssetCategory {
  id                    String             @id @default(cuid())
  tenantId              String
  code                  String
  name                  String
  usefulLifeMonths      Int                @default(60)
  residualValuePct      Float              @default(0)
  method                DepreciationMethod @default(STRAIGHT_LINE)
  decliningRate         Float?
  assetGlAccountId      String?
  accumDepGlAccountId   String?
  depExpenseGlAccountId String?
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assets                FixedAsset[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("fixed_asset_categories")
}

model FixedAsset {
  id                    String             @id @default(cuid())
  tenantId              String
  branchId              String?
  categoryId            String?
  code                  String
  name                  String
  description           String?
  status                FixedAssetStatus   @default(ACTIVE)
  acquisitionDate       DateTime
  cost                  Float
  residualValue         Float              @default(0)
  usefulLifeMonths      Int                @default(60)
  method                DepreciationMethod @default(STRAIGHT_LINE)
  decliningRate         Float?
  accumulatedDep        Float              @default(0)
  bookValue             Float
  location              String?
  serialNumber          String?
  vendorName            String?
  assetGlAccountId      String?
  accumDepGlAccountId   String?
  depExpenseGlAccountId String?
  disposedAt            DateTime?
  disposalProceeds      Float?
  disposalNotes         String?
  createdBy             String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category              FixedAssetCategory? @relation(fields: [categoryId], references: [id])
  depreciations         FixedAssetDepreciation[]
  transactions          FixedAssetTransaction[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, branchId])
  @@map("fixed_assets")
}

model FixedAssetDepreciation {
  id             String     @id @default(cuid())
  tenantId       String
  assetId        String
  periodLabel    String
  periodStart    DateTime
  periodEnd      DateTime
  amount         Float
  accumAfter     Float
  bookValueAfter Float
  journalEntryId String?
  postedAt       DateTime   @default(now())
  createdBy      String?

  asset          FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, periodLabel])
  @@index([tenantId, periodStart])
  @@index([assetId])
  @@map("fixed_asset_depreciations")
}

model FixedAssetTransaction {
  id             String            @id @default(cuid())
  tenantId       String
  assetId        String
  type           FixedAssetTxnType
  txnDate        DateTime          @default(now())
  amount         Float?
  description    String
  fromBranchId   String?
  toBranchId     String?
  fromLocation   String?
  toLocation     String?
  journalEntryId String?
  createdBy      String?
  createdAt      DateTime          @default(now())

  asset          FixedAsset        @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([tenantId, assetId])
  @@index([tenantId, txnDate])
  @@map("fixed_asset_transactions")
}

// ============================================================
// ACCOUNTING
// ============================================================

model Account {
  id                  String      @id @default(cuid())
  tenantId            String
  parentId            String?
  code                String
  name                String
  type                AccountType
  description         String?
  isSystem            Boolean     @default(false)
  isActive            Boolean     @default(true)
  balance             Float       @default(0)
  openingBalance      Float       @default(0)
  openingBalanceDate  DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent      Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children    Account[]     @relation("AccountHierarchy")
  debitLines  JournalLine[] @relation("DebitAccount")
  creditLines JournalLine[] @relation("CreditAccount")
  budgetLines AccountingBudgetLine[]
  accountMappings AccountMapping[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, parentId])
  @@map("accounts")
}

model FiscalYear {
  id              String           @id @default(cuid())
  tenantId        String
  name            String
  startDate       DateTime
  endDate         DateTime
  status          FiscalYearStatus @default(OPEN)
  isCurrent       Boolean          @default(false)
  closedAt        DateTime?
  closedBy        String?
  closingNotes    String?
  retainedEarningsAccountId String?
  createdBy       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periods         AccountingPeriod[]

  @@unique([tenantId, name])
  @@index([tenantId, status])
  @@index([tenantId, isCurrent])
  @@map("fiscal_years")
}

model AccountingPeriod {
  id            String                  @id @default(cuid())
  tenantId      String
  fiscalYearId  String
  name          String
  sequence      Int
  startDate     DateTime
  endDate       DateTime
  status        AccountingPeriodStatus  @default(OPEN)
  closedAt      DateTime?
  closedBy      String?
  reopenedAt    DateTime?
  reopenedBy    String?
  notes         String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fiscalYear    FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@unique([fiscalYearId, sequence])
  @@index([tenantId, status])
  @@index([tenantId, startDate, endDate])
  @@map("accounting_periods")
}

model JournalEntry {
  id          String             @id @default(cuid())
  tenantId    String
  branchId    String?
  entryNumber String
  description String
  referenceId String?
  referenceType String?
  date        DateTime           @default(now())
  status      JournalEntryStatus @default(DRAFT)
  isPosted    Boolean            @default(false)
  approvedBy  String?
  approvedAt  DateTime?
  postedAt    DateTime?
  voidedBy    String?
  voidedAt    DateTime?
  voidReason  String?
  createdBy   String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  lines       JournalLine[]

  @@unique([tenantId, entryNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, date])
  @@map("journal_entries")
}

model JournalLine {
  id              String           @id @default(cuid())
  journalEntryId  String
  debitAccountId  String?
  creditAccountId String?
  type            JournalEntryType
  amount          Float
  description     String?

  journalEntry    JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  debitAccount    Account?      @relation("DebitAccount", fields: [debitAccountId], references: [id])
  creditAccount   Account?      @relation("CreditAccount", fields: [creditAccountId], references: [id])

  @@index([journalEntryId])
  @@map("journal_lines")
}

model Expense {
  id          String   @id @default(cuid())
  tenantId    String
  branchId    String?
  categoryId  String?
  amount      Float
  description String
  date        DateTime
  reference   String?
  paymentMethod PaymentMethod @default(CASH)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
  @@map("expenses")
}

// ============================================================
// BANKING, CHEQUES, CASH BOOK (Phase 5 Finance)
// ============================================================

enum BankAccountType {
  CURRENT
  SAVINGS
  CASH_IN_HAND
  PETTY_CASH
}

enum BankTxnType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  FEE
  INTEREST
  ADJUSTMENT
  CHEQUE_CLEAR
}

enum BankTxnStatus {
  PENDING
  CLEARED
  VOID
}

enum ChequeDirection {
  RECEIVED
  ISSUED
}

enum ChequeStatus {
  RECEIVED
  ISSUED
  DEPOSITED
  CLEARED
  BOUNCED
  CANCELLED
}

enum BankReconciliationStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

model BankAccount {
  id             String          @id @default(cuid())
  tenantId       String
  branchId       String?
  code           String
  name           String
  type           BankAccountType @default(CURRENT)
  bankName       String?
  accountNumber  String?
  currency       String          @default("LKR")
  openingBalance Float           @default(0)
  currentBalance Float           @default(0)
  glAccountId    String?
  isActive       Boolean         @default(true)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions   BankTransaction[]
  cheques        Cheque[]
  reconciliations BankReconciliation[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("bank_accounts")
}

model BankTransaction {
  id            String        @id @default(cuid())
  tenantId      String
  bankAccountId String
  type          BankTxnType
  status        BankTxnStatus @default(CLEARED)
  amount        Float
  txnDate       DateTime      @default(now())
  valueDate     DateTime?
  reference     String?
  description   String?
  expenseId     String?
  chequeId      String?
  reconciliationId String?
  createdBy     String?
  createdAt     DateTime      @default(now())

  bankAccount   BankAccount   @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliation BankReconciliation? @relation(fields: [reconciliationId], references: [id])

  @@index([tenantId, bankAccountId])
  @@index([txnDate])
  @@map("bank_transactions")
}

model Cheque {
  id            String          @id @default(cuid())
  tenantId      String
  direction     ChequeDirection
  status        ChequeStatus
  chequeNumber  String
  bankName      String?
  amount        Float
  issueDate     DateTime?
  dueDate       DateTime?
  partyType     String?
  partyId       String?
  partyName     String?
  bankAccountId String?
  notes         String?
  clearedAt     DateTime?
  bouncedAt     DateTime?
  createdBy     String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount   BankAccount?    @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([dueDate])
  @@map("cheques")
}

model BankReconciliation {
  id                String                    @id @default(cuid())
  tenantId          String
  bankAccountId     String
  statementDate     DateTime
  statementBalance  Float
  systemBalance     Float
  difference        Float                     @default(0)
  status            BankReconciliationStatus  @default(DRAFT)
  notes             String?
  completedAt       DateTime?
  createdBy         String?
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bankAccount       BankAccount               @relation(fields: [bankAccountId], references: [id])
  matchedTxns       BankTransaction[]

  @@index([tenantId])
  @@index([bankAccountId])
  @@map("bank_reconciliations")
}

model CashBookEntry {
  id            String   @id @default(cuid())
  tenantId      String
  branchId      String?
  entryDate     DateTime @default(now())
  type          String
  description   String
  debit         Float    @default(0)
  credit        Float    @default(0)
  balanceAfter  Float    @default(0)
  referenceType String?
  referenceId   String?
  paymentMethod PaymentMethod?
  createdBy     String?
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entryDate])
  @@index([tenantId, branchId])
  @@map("cash_book_entries")
}

// ============================================================
// HR & EMPLOYEES
// ============================================================

model Employee {
  id              String         @id @default(cuid())
  tenantId        String
  branchId        String?
  userId          String?
  code            String?
  firstName       String
  lastName        String
  email           String?
  phone           String
  gender          Gender?
  dateOfBirth     DateTime?
  address         String?
  department      String?
  designation     String?
  employmentType  EmploymentType @default(FULL_TIME)
  joiningDate     DateTime
  leavingDate     DateTime?
  basicSalary     Float          @default(0)
  commissionRate  Float          @default(0)
  bankDetails     Json           @default("{}")
  epfNumber       String?
  etfNumber       String?
  nicNumber       String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?      @relation(fields: [branchId], references: [id])
  attendances     Attendance[]
  payrolls        Payroll[]
  payslips        Payslip[]
  shifts          EmployeeShift[]
  leaveRequests   LeaveRequest[]
  helperSales     Sale[]       @relation("HelperSales")

  @@index([tenantId])
  @@map("employees")
}

model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  tenantId    String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  createdAt   DateTime         @default(now())

  employee    Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@map("attendances")
}

// ============================================================
// PAYROLL (Sprint 10)
// ============================================================

enum PayrollComponentType {
  ALLOWANCE
  DEDUCTION
}

enum PayrollRunStatus {
  DRAFT
  CALCULATED
  APPROVED
  PAID
  CANCELLED
}

enum PayrollEntryStatus {
  DRAFT
  CALCULATED
  PAID
  CANCELLED
}

model PayrollSetting {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  epfEmployeeRate       Float    @default(8)
  epfEmployerRate       Float    @default(12)
  etfEmployerRate       Float    @default(3)
  epfWageCap            Float?
  salaryExpenseGlId     String?
  epfExpenseGlId        String?
  etfExpenseGlId        String?
  epfPayableGlId        String?
  etfPayableGlId        String?
  bankGlId              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("payroll_settings")
}

// ── Phase 06 Sprint 13 — Accounting Settings ─────────────────────────────

enum NumberSeriesResetPolicy {
  NEVER
  YEARLY
  MONTHLY
  DAILY
}

model DocumentNumberSeries {
  id             String                  @id @default(cuid())
  tenantId       String
  key            String
  name           String
  prefix         String
  includeYear    Boolean                 @default(true)
  includeMonth   Boolean                 @default(false)
  padLength      Int                     @default(5)
  resetPolicy    NumberSeriesResetPolicy @default(YEARLY)
  nextValue      Int                     @default(1)
  lastResetKey   String?
  isActive       Boolean                 @default(true)
  description    String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  tenant         Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("document_number_series")
}

model AccountingPreference {
  id                        String   @id @default(cuid())
  tenantId                  String   @unique
  requireJournalApproval    Boolean  @default(true)
  allowPostDraft            Boolean  @default(false)
  blockPostingClosedPeriod  Boolean  @default(true)
  fiscalYearStartMonth      Int      @default(1)
  decimalPlaces             Int      @default(2)
  autoPostEnabled           Boolean  @default(true)
  repairVatEnabled          Boolean  @default(false)
  defaultCashAccountId      String?
  defaultArAccountId        String?
  defaultApAccountId        String?
  defaultSalesAccountId     String?
  defaultPurchaseAccountId  String?
  defaultRetainedEarningsId String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("accounting_preferences")
}

enum AccountingOutboxStatus {
  PENDING
  PROCESSING
  POSTED
  FAILED
  SKIPPED
}

/// Configurable GL mapping key → account for commerce posting.
model AccountMapping {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  accountId String
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([accountId])
  @@map("account_mappings")
}

/// Durable accounting event queue for auto-post / manual sync.
model AccountingOutboxEvent {
  id             String                 @id @default(cuid())
  tenantId       String
  sourceType     String
  sourceId       String
  payload        Json                   @default("{}")
  status         AccountingOutboxStatus @default(PENDING)
  attempts       Int                    @default(0)
  lastError      String?
  journalEntryId String?
  processedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, sourceType, sourceId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("accounting_outbox_events")
}

// ============================================================
// ADVANCED ACCOUNTING
// ============================================================

model CostCenter {
  id          String   @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  manager     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  budgetLines AccountingBudgetLine[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@map("cost_centers")
}

model AccountingBudget {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  fiscalYear  Int
  status      String   @default("DRAFT")
  notes       String?
  createdBy   String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines       AccountingBudgetLine[]

  @@unique([tenantId, name, fiscalYear])
  @@index([tenantId, fiscalYear, status])
  @@map("accounting_budgets")
}

model AccountingBudgetLine {
  id           String   @id @default(cuid())
  budgetId     String
  accountId    String
  costCenterId String?
  month        Int
  amount       Float
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  budget       AccountingBudget @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  account      Account          @relation(fields: [accountId], references: [id], onDelete: Restrict)
  costCenter   CostCenter?      @relation(fields: [costCenterId], references: [id], onDelete: SetNull)

  @@unique([budgetId, accountId, costCenterId, month])
  @@index([budgetId, month])
  @@index([accountId])
  @@map("accounting_budget_lines")
}

model RecurringJournal {
  id            String   @id @default(cuid())
  tenantId      String
  name          String
  description   String
  frequency     String
  startDate     DateTime
  endDate       DateTime?
  nextRunDate   DateTime
  lastRunDate   DateTime?
  autoPost      Boolean  @default(true)
  isActive      Boolean  @default(true)
  branchId      String?
  lines         Json
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, isActive, nextRunDate])
  @@map("recurring_journals")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  tenantId     String
  fromCurrency String
  toCurrency   String
  rate         Float
  effectiveAt  DateTime
  source       String?
  isActive     Boolean  @default(true)
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, fromCurrency, toCurrency, effectiveAt])
  @@index([tenantId, effectiveAt])
  @@map("exchange_rates")
}

model PayrollComponent {
  id              String               @id @default(cuid())
  tenantId        String
  code            String
  name            String
  type            PayrollComponentType
  isEpfApplicable Boolean              @default(true)
  isPercent       Boolean              @default(false)
  defaultAmount   Float                @default(0)
  percentOfBasic  Float?
  isActive        Boolean              @default(true)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("payroll_components")
}

model PayrollRun {
  id                String           @id @default(cuid())
  tenantId          String
  month             Int
  year              Int
  periodLabel       String
  status            PayrollRunStatus @default(DRAFT)
  employeeCount     Int              @default(0)
  totalGross        Float            @default(0)
  totalAllowances   Float            @default(0)
  totalDeductions   Float            @default(0)
  totalEpfEmployee  Float            @default(0)
  totalEpfEmployer  Float            @default(0)
  totalEtf          Float            @default(0)
  totalNet          Float            @default(0)
  journalEntryId    String?
  notes             String?
  approvedAt        DateTime?
  paidAt            DateTime?
  createdBy         String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entries           Payroll[]

  @@unique([tenantId, month, year])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("payroll_runs")
}

model PayrollLine {
  id          String               @id @default(cuid())
  payrollId   String
  type        PayrollComponentType
  code        String
  name        String
  amount      Float
  componentId String?

  payroll     Payroll              @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
  @@map("payroll_lines")
}

model Payslip {
  id            String   @id @default(cuid())
  tenantId      String
  payrollId     String   @unique
  employeeId    String
  payslipNumber String
  periodLabel   String
  issuedAt      DateTime @default(now())
  snapshot      Json     @default("{}")
  createdAt     DateTime @default(now())

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payroll       Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employee      Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, periodLabel])
  @@index([employeeId])
  @@map("payslips")
}

model Payroll {
  id              String   @id @default(cuid())
  employeeId      String
  tenantId        String
  payrollRunId    String?
  month           Int
  year            Int
  basicSalary     Float
  allowances      Float    @default(0)
  deductions      Float    @default(0)
  bonus           Float    @default(0)
  commission      Float    @default(0)
  grossSalary     Float    @default(0)
  epfWage         Float    @default(0)
  epfEmployee     Float    @default(0)
  epfEmployer     Float    @default(0)
  etfEmployer     Float    @default(0)
  netSalary       Float
  status          PayrollEntryStatus @default(DRAFT)
  isPaid          Boolean  @default(false)
  paidAt          DateTime?
  paymentMethod   String?
  journalEntryId  String?
  payslipNumber   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  employee        Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollRun      PayrollRun? @relation(fields: [payrollRunId], references: [id])
  lines           PayrollLine[]
  payslip         Payslip?

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([tenantId, month, year])
  @@index([payrollRunId])
  @@map("payrolls")
}

model LeaveRequest {
  id          String   @id @default(cuid())
  employeeId  String
  tenantId    String
  startDate   DateTime
  endDate     DateTime
  leaveType   String   @default("CASUAL")
  reason      String?
  status      String   @default("PENDING")
  approvedBy  String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@map("leave_requests")
}

model Shift {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  startTime   String
  endTime     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  employees   EmployeeShift[]

  @@map("shifts")
}

model EmployeeShift {
  id          String   @id @default(cuid())
  employeeId  String
  shiftId     String
  date        DateTime
  isActive    Boolean  @default(true)

  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  shift       Shift    @relation(fields: [shiftId], references: [id])

  @@index([employeeId])
  @@map("employee_shifts")
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id          String              @id @default(cuid())
  tenantId    String
  type        NotificationType
  title       String
  message     String
  channel     NotificationChannel
  recipients  String[]
  data        Json                @default("{}")
  isRead      Boolean             @default(false)
  sentAt      DateTime?
  scheduledAt DateTime?
  createdAt   DateTime            @default(now())

  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userNotifs  UserNotification[]

  @@index([tenantId])
  @@index([tenantId, isRead, createdAt])
  @@index([tenantId, createdAt])
  @@map("notifications")
}

model UserNotification {
  id             String   @id @default(cuid())
  userId         String
  notificationId String
  isRead         Boolean  @default(false)
  readAt         DateTime?
  createdAt      DateTime @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@index([userId])
  @@index([userId, isRead])
  @@map("user_notifications")
}

// ============================================================
// FILE UPLOADS
// ============================================================

model FileUpload {
