# ============================================
# FASHION ERP - ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# ============================================

# Application
NODE_ENV=development
APP_NAME="Fashion ERP"
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ============================================
# DATABASE
# ============================================
DATABASE_URL="postgresql://postgres:password@localhost:5432/fashion_erp?schema=public"

# ============================================
# REDIS
# ============================================
REDIS_URL="redis://localhost:6379"
REDIS_TTL=3600

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-min-32-chars-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================
# AWS S3 / CLOUDFLARE R2 STORAGE
# ============================================
STORAGE_PROVIDER=s3  # s3 or r2

# AWS S3
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="fashion-erp-assets"

# Cloudflare R2 (alternative)
R2_ENDPOINT="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret-key"
R2_BUCKET="fashion-erp-assets"
R2_PUBLIC_URL="https://assets.yourdomain.com"

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"
SMTP_FROM="Fashion ERP <noreply@fashionerp.com>"

# ============================================
# WHATSAPP API
# ============================================
WHATSAPP_API_URL="https://api.whatsapp.com/v1"
WHATSAPP_API_TOKEN="your-whatsapp-business-api-token"
WHATSAPP_PHONE_ID="your-phone-number-id"

# ============================================
# SMS GATEWAY
# ============================================
SMS_PROVIDER=twilio  # twilio, msg91, fast2sms
SMS_API_KEY="your-sms-api-key"
SMS_SENDER_ID="FASHNERP"
TWILIO_ACCOUNT_SID="your-twilio-account-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ============================================
# ELASTICSEARCH
# ============================================
ELASTICSEARCH_URL="http://localhost:9200"
ELASTICSEARCH_INDEX_PREFIX="fashion_erp"

# ============================================
# STRIPE (ONLINE PAYMENTS)
# ============================================
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ============================================
# KEYCLOAK SSO
# ============================================
KEYCLOAK_AUTH_ENABLED=false
KEYCLOAK_URL=https://auth.hexalyte.com
KC_REALM=fashion-erp
KC_CLIENT_ID=fashion-erp-api
KC_CLIENT_SECRET=your-keycloak-client-secret

# ============================================
# GOOGLE OAUTH
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# ============================================
# 2FA / TOTP
# ============================================
TOTP_ISSUER="FashionERP"

# ============================================
# AI / OPENAI
# ============================================
OPENAI_API_KEY="sk-your-openai-api-key"
OPENAI_MODEL="gpt-4o-mini"

# ============================================
# PUSH NOTIFICATIONS (Firebase)
# ============================================
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="your-firebase-private-key"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project.iam.gserviceaccount.com"

# ============================================
# NEXT.JS PUBLIC VARIABLES
# ============================================
NEXT_PUBLIC_APP_NAME="Fashion ERP"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
